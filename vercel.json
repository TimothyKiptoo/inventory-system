{
  "version": 2,
  "outputDirectory": "frontend",
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/barcodes/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
